# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# WalletConnect (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Public site URL (link generation, Open Graph / X preview images — must be https in production).
# Use the exact hostname you share (with or without www), e.g. https://www.usepay.me
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayRouter — set to `false` to use direct ERC-20 transfer only
NEXT_PUBLIC_PAY_ROUTER_ADDRESS=0x49197480Afe1f6592324Fa0a5eE389b4C3EdC2b6

# GiftDistributor — deploy contracts/src/GiftDistributor.sol; omit or `false` to disable /gifts/create
# Constructor: (owner, [USDC, EURC addresses], feeRecipient, initialCreationFeeWei)
# Example initialCreationFeeWei: 500000 (= 0.5 with 6 decimals). No underscores (Remix/ethers reject 500_000).
# NEXT_PUBLIC_GIFT_DISTRIBUTOR_ADDRESS=0x...

# ERC-8004 platform agent
# Private keys must be 0x-prefixed Arc Testnet wallets funded with testnet USDC for gas.
PAYME_AGENT_OWNER_PRIVATE_KEY=0xYOUR_OWNER_PRIVATE_KEY
PAYME_AGENT_VALIDATOR_PRIVATE_KEY=0xYOUR_VALIDATOR_PRIVATE_KEY
# Shared secret required to trigger the one-time registration endpoint.
PAYME_AGENT_ADMIN_SECRET=your-random-admin-secret
# Optional: use your own metadata URI instead of the generated JSON endpoint.
# PAYME_AGENT_METADATA_URI=https://your-domain.com/api/agents/platform/metadata
PAYME_AGENT_METADATA_URI=ipfs://your-metadata-cid
